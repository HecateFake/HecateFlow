#ifndef _CONFIG_{{MODULE_UPPER}}_H_
#define _CONFIG_{{MODULE_UPPER}}_H_

#include <stdint.h>

/*
 * {{TARGET_ID}} 参数调节头(config{{MODULE_PASCAL}})— 编译期参数单一真相源
 *
 * 集中原散落在各 .c 的控制参数与时序宏,按 §分节组织。引脚集中在 pinMap.h(本文件不含引脚)。
 *
 * 量纲约定(必填,防数量级混用):
 *   {{UNIT_NOTE}}  例:速度域=编码器脉冲/2ms(PID 增益吸收尺度,无物理换算);几何 m;电流 ADC 原始量;时序 µs/ms/tick。
 *
 * 持久化语义:编译期宏=真相源;若有运行时 RAM 镜像/菜单热重载,镜像为可调子集。
 *   flash blob 必带 magic/version/payloadBytes/CRC;上电先 load defaults,再用校验通过的 blob 覆盖。
 *   只有 magic 正确且 version 不符时才走登记迁移或写回门;CRC/magic/payloadBytes 错保留默认且不自动覆盖 flash。
 *   flash erase/write 阻塞且有寿命,只能在 init/低风险阶段,不得进 ISR/控制 tick/通信热路径(见 hf-doc-discipline / hf-embedded-safety)。
 *
 * 分节索引:
 *   §A 调度时序与模式(ISR 周期 / 分频 / 构建模式宏)
 *   §B/§C/§D 各控制环参数(如速度环 / 电流环 / 角速度环;多实例则各实例独立增益)
 *   §E 几何 + 限幅 + 滤波
 *   §极性 方向系数单一真相源(执行器/编码器/电流 *_DIR)
 *   §F 通信映射 / 故障保护 / 其它
 */

/* ============================================================
 * §A 调度时序与模式
 * ============================================================ */
#define SAMPLE_PERIOD_US   ({{SAMPLE_US}}u)  /* 高优先采样 ISR 周期 */
#define CONTROL_PERIOD_US  ({{CONTROL_US}}u) /* 控制心跳周期 */
#define {{LOOP}}_DIVIDER   ({{DIV}}u)        /* 控制环分频 */

/* 编译期构建变体(多层模式须三处守卫对齐:定义/调用/ISR 路由,漏判致某分支链接 undefined) */
#define {{BUILD_MODE_A}} (0u)
#define {{BUILD_MODE_B}} (1u)
#define {{BUILD_MODE}}   {{BUILD_MODE_A}}

/* ============================================================
 * §B 控制环 PID(多实例则各实例独立增益)
 *   Kp **统一正号**:极性补偿已下沉到 §极性 方向系数,Kp 不兼任极性翻转器
 *   (避免负号反直觉 / 误改即正反馈失控)。见 hf-hw-mapping。
 * ============================================================ */
#define {{LOOP}}_INTEGRAL_MAX ({{IMAX}}f)
#define {{LOOP}}_{{INST_A}}_KP ({{KP_A}}f)
#define {{LOOP}}_{{INST_A}}_KI ({{KI_A}}f)
#define {{LOOP}}_{{INST_A}}_KD ({{KD_A}}f)

/* ============================================================
 * §E 几何 + 限幅 + 滤波
 * ============================================================ */
#define {{GEOM_PARAM}}     ({{GEOM_VAL}}f) /* 物理几何,单位 m */
#define {{OUTPUT_LIMIT}}   ({{LIMIT_VAL}}f) /* 执行器输出钳幅(±LIMIT,必须有) */
#define {{FEEDBACK_LPF}}   ({{LPF_VAL}}f)  /* 反馈低通系数(1.0=不启用) */

/* ------------------------------------------------------------
 * §极性 方向系数单一真相源("正方向 = 正" 不变量)
 *   约定:每实例物理正方向 ⇒ 正执行器命令 + 正反馈。三组方向系数各自吸收
 *   接线 / 编码器相位 / 采样方向,把"正方向=正"归一到上层,使各环 Kp 全用正号。
 *   各 ±1 由**开环实测辨识**(给正命令 → 看执行器方向 / 各反馈符号),非固定;
 *   换硬件 / 重接线须重辨识。改任一系数前**必核实物理接线**,同实例 输出/编码器/电流
 *   三者方向自洽且与 Kp 同号成对成立负反馈(Kp×反馈斜率<0)。
 *   注:闭环(如 yaw/航向环)另需"传感器正向 = 被控量正向",开环单实例辨识不覆盖,须手动确认。
 *   ★ agent 改/读本段时**主动提醒用户核实接线并请其确认**(见 hf-hw-mapping / hf-embedded-safety)。
 * ------------------------------------------------------------ */
/* (1) 执行器输出 *_OUTPUT_DIR:driver 乘命令,使 +命令 → 物理正方向 */
#define {{ACTUATOR}}_{{INST_A}}_OUTPUT_DIR (+1.0f)
/* (2) 编码器 ENCODER_*_DIR:乘原始计数,使 正方向 → +速度反馈 */
#define ENCODER_{{INST_A}}_DIR (+1)
/* (3) 电流 CURRENT_SENSE_*_DIR:乘 (raw-offset),使 正方向 → +电流反馈 */
#define CURRENT_SENSE_{{INST_A}}_DIR (+1)

/* ============================================================
 * §F 故障保护 / 通信映射
 *   失控保护:最内环输出持续饱和 → 失控信号。检测须落"所有控制模式必经的输出关口"。
 * ============================================================ */
#define {{RUNAWAY}}_SAT_THRESHOLD ({{SAT}}f) /* 输出饱和判定阈值(≈OUTPUT_LIMIT) */
#define {{RUNAWAY}}_TICKS         ({{RUN_TICKS}}u) /* 持续饱和触发拍数 → 持久锁定 + 告警 */

#endif /* _CONFIG_{{MODULE_UPPER}}_H_ */
