#ifndef _PIN_MAP_H_
#define _PIN_MAP_H_

/*
 * {{TARGET_ID}} 硬件映射头(pinMap)— 引脚单一真相源
 *
 * 集中原散落在各驱动 .c(motor/encoder/currentSense/key/comm...)的引脚定义。
 * 零依赖纯 #define:消费 .c 各自 include 对应驱动头展开 token(TCPWM/ADC/GPIO 枚举值
 * 由各驱动头提供,本文件不引头),保证本头无编译依赖、可被任意模块安全 include。
 *
 * 命名约定:{功能}_{通道/轮/实例}_{类型}。如 MOTOR_FL_EN_PWM / ENCODER_FR_CH1 / CURRENT_SENSE_BL_ADC。
 * 非引脚的频率/步长/时序/增益参数不在此(在 configHeader 或各模块本地)。
 *
 * 极性/方向系数**不在本文件**:它们属"参数"而非"引脚",集中在 configHeader 的 §极性段
 * (执行器输出 *_OUTPUT_DIR / 编码器 ENCODER_*_DIR / 电流 CURRENT_SENSE_*_DIR),
 * 见 hf-hw-mapping。本文件改动须同步跨核引脚冲突矩阵 docs/PINOUT(先改本头再更新矩阵)。
 */

/* ============================================================
 * 执行器驱动(如电机:使能 PWM + 方向 GPIO)
 * ============================================================ */
#define {{ACTUATOR}}_{{CH_A}}_EN_PWM ({{PWM_TOKEN_A}})
#define {{ACTUATOR}}_{{CH_A}}_PH_PIN ({{GPIO_TOKEN_A}})
/* ... 其余通道按 {功能}_{通道}_{类型} 续 ... */

/* ============================================================
 * 反馈传感器(如正交编码器:通道索引 + A/B 相引脚)
 * ============================================================ */
#define ENCODER_{{CH_A}}_INDEX ({{ENC_INDEX_A}})
#define ENCODER_{{CH_A}}_CH1   ({{ENC_CH1_A}})
#define ENCODER_{{CH_A}}_CH2   ({{ENC_CH2_A}})

/* ============================================================
 * 模拟采样(如电流 ADC)
 * ============================================================ */
#define {{SENSE}}_{{CH_A}}_ADC ({{ADC_TOKEN_A}})

/* ============================================================
 * 人机接口(按键 / 蜂鸣器 / 指示灯)
 *   按键丝印顺序可能与其它板反向 —— 注明,避免误映射。
 * ============================================================ */
#define {{KEY_PREFIX}}_{{KEY1}}_PIN ({{KEY1_TOKEN}})
#define {{BEEP_NAME}}_PIN           ({{BEEP_TOKEN}})

/* ============================================================
 * 通信收发器(如 RS-485:方向控制 + RX + TX)
 *   方向控制引脚(RE#/DE)的高低电平语义在此注明。
 * ============================================================ */
#define {{COMM}}_DIR_PIN ({{COMM_DIR_TOKEN}}) /* 高=发送 / 低=接收 */
#define {{COMM}}_RX_PIN  ({{COMM_RX_TOKEN}})
#define {{COMM}}_TX_PIN  ({{COMM_TX_TOKEN}})

#endif /* _PIN_MAP_H_ */
